# ─── Database (single Postgres, schema-per-service) ───
POSTGRES_USER=attrition_user
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=attrition

# ─── JWT (shared by ALL services — must be byte-identical, >=32 chars) ───
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long-change-this
JWT_ISSUER=attrition-api
JWT_AUDIENCE=attrition-web
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ─── Service-to-service auth (Search/Admin → Identity internal endpoints) ───
INTERNAL_API_KEY=change-this-to-a-long-random-internal-key

# ─── Google OAuth (Identity validates ID tokens with ClientId) ───
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ─── URLs ───
# Used in verification/reset email links
APP_CLIENT_URL=https://your-domain.com
# CORS allow-list at the gateway (comma-separated)
CORS_ORIGINS=https://your-domain.com,http://localhost:3000
# Frontend (Next.js) public vars
NEXT_PUBLIC_API_URL=https://your-domain.com
NEXT_PUBLIC_WEB_URL=https://your-domain.com
NEXT_PUBLIC_COLLECTION_URL=https://collection.your-domain.com

# ─── File upload ───
MAX_AVATAR_SIZE_MB=5
UPLOAD_PATH=/app/uploads

# ─── Cloudflare tunnel (token-based; ingress configured in CF dashboard → nginx:80) ───
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

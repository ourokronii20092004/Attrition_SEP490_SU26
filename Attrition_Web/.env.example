# ─── Database (single Postgres, schema-per-service) ───
POSTGRES_USER=attrition_user
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=attrition

# ─── Database backups (db-backup service; see docs/backups.md) ───
# Backups are written to BACKUP_HOST_DIR on the host — keep this OUTSIDE the project dir
# (/opt/attrition) so deploy.py's project-dir wipe can never delete them.
BACKUP_HOST_DIR=/opt/attrition-backups
BACKUP_INTERVAL_HOURS=24
BACKUP_KEEP=7
# Optional off-host shipping via rclone (e.g. b2:attrition-backups). Leave blank to keep
# backups on the host only. Requires an rclone.conf mounted into the db-backup container.
BACKUP_RCLONE_REMOTE=

# ─── Redis (cache layer; ephemeral, degrades gracefully if down) ───
REDIS_CONNECTION=redis:6379
REDIS_DEFAULT_TTL_MINUTES=10

# ─── JWT (shared by ALL services — must be byte-identical, >=32 chars) ───
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long-change-this
JWT_ISSUER=attrition-api
JWT_AUDIENCE=attrition-web
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ─── Service-to-service auth (Search/Admin → Identity internal endpoints) ───
# MUST be rotated to a long random value before any non-local deployment.
INTERNAL_API_KEY=change-this-to-a-long-random-internal-key

# ─── Seeded admin account (Identity creates it on startup if the username is
#     missing from the DB; leave ADMIN_USERNAME blank to disable seeding) ───
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-admin-password
ADMIN_EMAIL=admin@your-domain.com

# ─── Google OAuth (Identity validates ID tokens with ClientId) ───
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ─── URLs ───
# Used in verification/reset email links
APP_CLIENT_URL=https://your-domain.com
# CORS allow-list at the gateway (comma-separated)
CORS_ORIGINS=https://your-domain.com,http://localhost:3000
# Frontend (Next.js) public vars
NEXT_PUBLIC_API_URL=https://your-domain.com
NEXT_PUBLIC_WEB_URL=https://your-domain.com
NEXT_PUBLIC_COLLECTION_URL=https://collection.your-domain.com

# ─── File upload ───
MAX_AVATAR_SIZE_MB=5
UPLOAD_PATH=/app/uploads
# Max asset (image/document) upload size in MB. Music tracks are capped separately at 100MB.
ASSET_MAX_SIZE_MB=50

# ─── SMTP (Identity sends verification / password-reset email) ───
# For Gmail: host smtp.gmail.com, port 587, and an App Password (not your login password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_ADDRESS=your-email@gmail.com
SMTP_FROM_NAME=Attrition
SMTP_ENABLE_SSL=true

# ─── Host port exposure ───
# Both default to 127.0.0.1 so the gateway/nginx are only reachable from the host loopback.
# In prod, cloudflared → nginx and nginx → gateway both travel the internal docker network,
# so loopback binding does NOT break the edge. Set to 0.0.0.0 ONLY if you must reach these
# from another machine (e.g. LAN testing) and understand it bypasses the cloudflared/nginx edge.
GATEWAY_HOST_BIND=127.0.0.1
GATEWAY_HOST_PORT=8080
WEB_HOST_BIND=127.0.0.1
WEB_HOST_PORT=3000

# ─── Cloudflare tunnel (token-based; ingress configured in CF dashboard → nginx:80) ───
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

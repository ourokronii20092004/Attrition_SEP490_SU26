# ─── Database ───
POSTGRES_USER=attrition_user
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=attrition

# ─── JWT (shared by ALL services — must be byte-identical, >= 32 chars for HS256) ───
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long-change-this
JWT_ISSUER=attrition-api
JWT_AUDIENCE=attrition-web
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# ─── Internal service-to-service key (Search/Admin -> internal endpoints) ───
INTERNAL_API_KEY=change-this-internal-service-key

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ─── URLs ───
# nginx is the public edge; gateway is internal. Frontend talks to the public host.
NEXT_PUBLIC_WEB_URL=https://attrition.io.vn
NEXT_PUBLIC_API_URL=https://attrition.io.vn

# ─── Cloudflare ───
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

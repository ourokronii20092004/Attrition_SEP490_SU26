{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://attrition.io.vn" ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth":        { "ClusterId": "identity", "Order": 1, "Match": { "Path": "/api/auth/{**catch-all}" } },
      "account":     { "ClusterId": "identity", "Order": 1, "Match": { "Path": "/api/account/{**catch-all}" } },
      "enemies":     { "ClusterId": "enemy",    "Order": 1, "Match": { "Path": "/api/enemies/{**catch-all}" } },
      "wiki":        { "ClusterId": "wiki",     "Order": 1, "Match": { "Path": "/api/wiki/{**catch-all}" } },
      "forum":       { "ClusterId": "forum",    "Order": 1, "Match": { "Path": "/api/forum/{**catch-all}" } },
      "assets":      { "ClusterId": "assets",   "Order": 1, "Match": { "Path": "/api/assets/{**catch-all}" } },
      "music":       { "ClusterId": "music",    "Order": 1, "Match": { "Path": "/api/music/{**catch-all}" } },
      "search":      { "ClusterId": "search",   "Order": 1, "Match": { "Path": "/api/search/{**catch-all}" } },

      "adminUsers":  { "ClusterId": "identity", "Order": 0, "Match": { "Path": "/api/admin/users/{**catch-all}" } },
      "adminForum":  { "ClusterId": "forum",    "Order": 0, "Match": { "Path": "/api/admin/forum/{**catch-all}" } },
      "adminAssets": { "ClusterId": "assets",   "Order": 0, "Match": { "Path": "/api/admin/assets/{**catch-all}" } },
      "admin":       { "ClusterId": "admin",    "Order": 2, "Match": { "Path": "/api/admin/{**catch-all}" } }
    },
    "Clusters": {
      "identity": { "Destinations": { "d1": { "Address": "http://identity-service:8080/" } } },
      "enemy":    { "Destinations": { "d1": { "Address": "http://enemy-service:8080/" } } },
      "wiki":     { "Destinations": { "d1": { "Address": "http://wiki-service:8080/" } } },
      "forum":    { "Destinations": { "d1": { "Address": "http://forum-service:8080/" } } },
      "assets":   { "Destinations": { "d1": { "Address": "http://assets-service:8080/" } } },
      "music":    { "Destinations": { "d1": { "Address": "http://music-service:8080/" } } },
      "search":   { "Destinations": { "d1": { "Address": "http://search-service:8080/" } } },
      "admin":    { "Destinations": { "d1": { "Address": "http://admin-service:8080/" } } }
    }
  }
}

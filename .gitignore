# =============================================
# Attrition SEP490 - Root .gitignore
# Covers: Unity (Attrition_Game) + Web (Attrition_Web)
# =============================================

# ---- OS generated files ----
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ---- IDE / Editor ----
.vs/
.vscode/
.idea/
*.suo
*.user
*.userprefs
*.DotSettings.user

# =============================================
# Unity (Attrition_Game) — scoped to game dir
# =============================================
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore

.utmp/
Attrition_Game/[Ll]ibrary/
Attrition_Game/[Tt]emp/
Attrition_Game/[Oo]bj/
Attrition_Game/[Bb]uild/
Attrition_Game/[Bb]uilds/
Attrition_Game/[Ll]ogs/
Attrition_Game/[Uu]ser[Ss]ettings/
*.log

# Blender
*.blend1
*.blend1.meta

# MemoryCaptures
Attrition_Game/[Mm]emoryCaptures/

# Recordings
Attrition_Game/[Rr]ecordings/

# Autogenerated Jetbrains Rider plugin
Attrition_Game/[Aa]ssets/Plugins/Editor/JetBrains*

# Gradle cache directory
.gradle/

# Unity autogenerated solution/project files (scoped to game only)
Attrition_Game/ExportedObj/
Attrition_Game/*.csproj
Attrition_Game/*.unityproj
Attrition_Game/*.sln
Attrition_Game/*.tmp
.consulo/
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# TestRunner generated files
InitTestScene*.unity*

# Addressables
Attrition_Game/ServerData
Attrition_Game/[Aa]ssets/StreamingAssets/aa*
Attrition_Game/[Aa]ssets/AddressableAssetsData/link.xml*
Attrition_Game/[Aa]ssets/Addressables_Temp*
Attrition_Game/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
Attrition_Game/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
Attrition_Game/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
Attrition_Game/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
Attrition_Game/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
Attrition_Game/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# =============================================
# .NET / C# (Attrition_Web/api)
# =============================================
# Note: .csproj and .sln ARE tracked for .NET projects (unlike Unity)
Attrition_Web/api/bin/
Attrition_Web/api/obj/

# =============================================
# Node.js / Next.js (Attrition_Web/web)
# =============================================
**/node_modules/
**/.next/
**/out/
*.tsbuildinfo
next-env.d.ts
.pnp
.pnp.js
.yarn/install-state.gz
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================
# Environment & Secrets (CRITICAL)
# =============================================
.env
.env.local
.env.*.local
*.env.local

# =============================================
# Docker
# =============================================
docker-compose.override.yml

# =============================================
# Uploads & Media (user-generated)
# =============================================
uploads/

# =============================================
# Vercel
# =============================================
.vercel

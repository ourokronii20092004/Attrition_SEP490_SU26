# ============================================================
# Unity .gitignore - Attrition Project
# Only push YOUR work: scripts, scenes, prefabs, assets, etc.
# ============================================================

# ---- Unity Generated ----
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# ---- IDE & Editor Files ----
# Visual Studio
.vs/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
ExportedObj/

# JetBrains Rider
.idea/
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# VS Code
.vscode/

# Consulo
.consulo/

# ---- OS Generated Files ----
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.directory

# ---- Blender ----
*.blend1
*.blend1.meta

# ---- Unity3D Generated Meta Files ----
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ---- Unity Crash Reports ----
sysinfo.txt

# ---- Mono Auto Generated ----
mono_crash.*

# ---- Memory Captures (can be large & sensitive) ----
/[Mm]emoryCaptures/

# ---- Recordings (can be large) ----
/[Rr]ecordings/

# ---- Builds / Packages ----
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
*.exe
*.dll
!Assets/**/*.dll

# ---- Crashlytics ----
crashlytics-build.properties

# ---- TestRunner ----
InitTestScene*.unity*

# ---- Addressables ----
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# ---- Visual Scripting Auto-Generated ----
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# ---- Auto-generated test scenes ----
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# ---- Photon / Fusion ----
# Photon config chứa AppId (nhạy cảm) - uncomment nếu bạn không muốn push
# /[Aa]ssets/Photon/Fusion/Resources/PhotonAppSettings.asset
# /[Aa]ssets/Photon/Fusion/Resources/PhotonAppSettings.asset.meta

# ---- Gradle (Android builds) ----
.gradle/

# ---- Misc project files ----
Temp.txt

# ---- NuGet ----
*.nupkg
packages/

# ---- Compression / Archives ----
*.zip
*.rar
*.7z
*.tar
*.gz
